---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '@/lib/reading-time';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data } = post;
const readingTime = post.body
	? Math.max(1, Math.ceil(post.body.trim().split(/\s+/).length / 200))
	: 3;
---

<article class="group relative overflow-hidden rounded-2xl border bg-card text-card-foreground shadow-sm transition-all duration-500 hover:shadow-xl hover:shadow-primary/5 hover:-translate-y-1.5 hover:border-primary/30 cursor-pointer">
	<div class="absolute inset-0 -z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-700">
		<div class="absolute inset-0 bg-gradient-to-br from-primary/[0.03] via-transparent to-purple-500/[0.03]" />
	</div>
	<a href={`/blog/${post.id}`} class="block">
		{data.heroImage ? (
			<div class="relative aspect-[16/10] overflow-hidden">
                <img
                    src={data.heroImage}
                    alt={data.title}
                    class="h-full w-full object-cover object-center transition-all duration-700 group-hover:scale-110"
                    loading="lazy"
                    width={400}
                    height={250}
                />
				<div class="absolute inset-0 bg-gradient-to-t from-card via-card/30 to-transparent" />
				<div class="absolute top-3 right-3">
					<span class="inline-flex items-center rounded-full bg-background/80 backdrop-blur-sm px-2.5 py-1 text-[11px] font-medium text-foreground shadow-xs">
						<svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
							<circle cx="12" cy="12" r="10" />
						</svg>
						{readingTime} min
					</span>
				</div>
			</div>
		) : (
			<div class="relative aspect-[16/10] bg-gradient-to-br from-primary/5 via-purple-500/5 to-pink-500/5 flex items-center justify-center">
				<svg class="w-10 h-10 text-muted-foreground/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
				</svg>
				<div class="absolute top-3 right-3">
					<span class="inline-flex items-center rounded-full bg-background/80 backdrop-blur-sm px-2.5 py-1 text-[11px] font-medium text-foreground shadow-xs">
						<svg class="w-3 h-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
							<circle cx="12" cy="12" r="10" />
						</svg>
						{readingTime} min
					</span>
				</div>
			</div>
		)}
		<div class="p-5">
			<div class="flex items-center gap-3 text-xs text-muted-foreground mb-3">
				<time datetime={data.pubDate.toISOString()} class="flex items-center gap-1.5">
					<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
						<line x1="16" y1="2" x2="16" y2="6" />
						<line x1="8" y1="2" x2="8" y2="6" />
						<line x1="3" y1="10" x2="21" y2="10" />
					</svg>
					{formatDate(data.pubDate)}
				</time>
			</div>
			<h2 class="text-lg font-bold leading-snug mb-2 transition-colors duration-300 group-hover:text-primary">
				{data.title}
			</h2>
			<p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">
				{data.description}
			</p>
			{data.tags && data.tags.length > 0 && (
				<div class="flex flex-wrap gap-1.5 mt-4 pt-4 border-t border-border/40">
					{data.tags.slice(0, 3).map((tag) => (
						<span class="inline-flex items-center rounded-full bg-secondary/60 px-2.5 py-0.5 text-[11px] font-medium text-secondary-foreground hover:bg-secondary transition-colors">
							#{tag}
						</span>
					))}
					{data.tags.length > 3 && (
						<span class="inline-flex items-center rounded-full bg-secondary/60 px-2.5 py-0.5 text-[11px] font-medium text-secondary-foreground">
							+{data.tags.length - 3}
						</span>
					)}
				</div>
			)}
		</div>
	</a>
</article>
