---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import BlogPost from '@/components/BlogPost.astro';
import { BGPattern } from '@/components/ui/bg-pattern';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const posts = allPosts.sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
const totalReadingTime = posts.reduce((acc, post) => {
	return acc + (post.body ? Math.max(1, Math.ceil(post.body.trim().split(/\s+/).length / 200)) : 3);
}, 0);
---

<Layout>
	<main>
		<section class="relative pt-28 pb-16 px-5 ">
			<BGPattern variant="dots" mask="fade-edges" size={20} fill="hsl(var(--foreground) / 0.04)" />
			<div class="absolute inset-0 -z-10">
				<div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-primary/8 rounded-full blur-3xl" />
				<div class="absolute top-40 right-1/4 w-72 h-72 bg-purple-500/5 rounded-full blur-3xl" />
				<div class="absolute bottom-0 left-1/3 w-96 h-48 bg-primary/5 rounded-full blur-3xl" />
			</div>
			<div class="max-w-4xl mx-auto text-center">
				<div class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-medium mb-6 bg-secondary/50 text-secondary-foreground backdrop-blur-sm">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75" />
						<span class="relative inline-flex rounded-full h-2 w-2 bg-primary" />
					</span>
					{posts.length} {posts.length === 1 ? 'article' : 'articles'} published
				</div>
				<h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-4 ">
					Blogs
				</h1>
				<p class="text-lg text-muted-foreground max-w-2xl mx-auto leading-relaxed">
					Thoughts on software engineering, web development, and building things that matter.
				</p>
			</div>

			<div class="max-w-2xl mx-auto mt-10 grid grid-cols-3 gap-4">
				<div class="rounded-xl border bg-card/50 backdrop-blur-sm p-4 text-center hover:bg-card/80 transition-colors">
					<div class="flex items-center justify-center gap-2 mb-1">
						<svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
						</svg>
						<span class="text-2xl font-bold text-foreground">{posts.length}</span>
					</div>
					<p class="text-xs text-muted-foreground">Articles</p>
				</div>
				<div class="rounded-xl border bg-card/50 backdrop-blur-sm p-4 text-center hover:bg-card/80 transition-colors">
					<div class="flex items-center justify-center gap-2 mb-1">
						<svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
						</svg>
						<span class="text-2xl font-bold text-foreground">{allTags.length}</span>
					</div>
					<p class="text-xs text-muted-foreground">Topics</p>
				</div>
				<div class="rounded-xl border bg-card/50 backdrop-blur-sm p-4 text-center hover:bg-card/80 transition-colors">
					<div class="flex items-center justify-center gap-2 mb-1">
						<svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
							<circle cx="12" cy="12" r="10" />
						</svg>
						<span class="text-2xl font-bold text-foreground">{totalReadingTime}</span>
					</div>
					<p class="text-xs text-muted-foreground">Min read</p>
				</div>
			</div>
		</section>

		<section class="relative pb-24 px-5">
			<BGPattern variant="grid" mask="fade-top" size={32} fill="hsl(var(--foreground) / 0.03)" />
			<div class="max-w-6xl mx-auto">
				{allTags.length > 0 && (
					<div class="flex flex-wrap justify-center gap-2 mb-12">
						<button
							class="tag-filter inline-flex items-center rounded-full border px-4 py-1.5 text-sm font-medium transition-all duration-300 hover:bg-accent hover:text-accent-foreground cursor-pointer data-[active=true]:bg-foreground data-[active=true]:text-background data-[active=true]:border-foreground"
							data-tag="all"
							data-active="true"
						>
							All Posts
						</button>
						{allTags.map((tag) => (
							<button
								class="tag-filter inline-flex items-center rounded-full border px-4 py-1.5 text-sm font-medium transition-all duration-300 hover:bg-accent hover:text-accent-foreground cursor-pointer data-[active=true]:bg-foreground data-[active=true]:text-background data-[active=true]:border-foreground"
								data-tag={tag}
							>
								#{tag}
							</button>
						))}
					</div>
				)}

				<div id="blog-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
					{posts.map((post, index) => (
						<div
							class="blog-card stagger-item"
							data-tags={post.data.tags.join(",")}
							style={`view-transition-name: blog-card-${index}`}
						>
							<BlogPost post={post} />
						</div>
					))}
				</div>

				<div id="no-results" class="text-center py-32 hidden">
					<div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-secondary mb-6">
						<svg class="w-8 h-8 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
						</svg>
					</div>
					<p class="text-muted-foreground text-lg font-medium">No posts match this topic</p>
					<p class="text-muted-foreground/60 text-sm mt-1">Try selecting a different tag</p>
				</div>

				{posts.length === 0 && (
					<div class="text-center py-32">
						<div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-secondary mb-6">
							<svg class="w-8 h-8 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
							</svg>
						</div>
						<p class="text-muted-foreground text-lg font-medium">No posts yet</p>
						<p class="text-muted-foreground/60 text-sm mt-1">Check back soon for new articles!</p>
					</div>
				)}
			</div>
		</section>
	</main>
</Layout>

<style is:global>
	.tag-filter[data-active="true"] {
		background-color: hsl(var(--foreground));
		color: hsl(var(--background));
		border-color: hsl(var(--foreground));
	}

	@keyframes stagger-fade-in {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.stagger-item {
		animation: stagger-fade-in 0.5s ease-out both;
	}

	.stagger-item:nth-child(1) { animation-delay: 0s; }
	.stagger-item:nth-child(2) { animation-delay: 0.05s; }
	.stagger-item:nth-child(3) { animation-delay: 0.1s; }
	.stagger-item:nth-child(4) { animation-delay: 0.15s; }
	.stagger-item:nth-child(5) { animation-delay: 0.2s; }
	.stagger-item:nth-child(6) { animation-delay: 0.25s; }
	.stagger-item:nth-child(7) { animation-delay: 0.3s; }
	.stagger-item:nth-child(8) { animation-delay: 0.35s; }
	.stagger-item:nth-child(9) { animation-delay: 0.4s; }
	.stagger-item:nth-child(10) { animation-delay: 0.45s; }

	@media (prefers-reduced-motion: reduce) {
		.stagger-item {
			animation: none;
		}
	}
</style>

<script>
	const filters = document.querySelectorAll<HTMLButtonElement>(".tag-filter");
	const cards = document.querySelectorAll<HTMLElement>(".blog-card");
	const noResults = document.getElementById("no-results");
	const grid = document.getElementById("blog-grid");

	function updateFilter(activeTag: string) {
		filters.forEach((btn) => {
			const tag = btn.dataset.tag;
			btn.dataset.active = tag === activeTag ? "true" : "false";
		});

		let visibleCount = 0;
		cards.forEach((card) => {
			const tags = card.dataset.tags?.split(",") ?? [];
			const shouldShow = activeTag === "all" || tags.includes(activeTag);
			card.style.display = shouldShow ? "" : "none";
			if (shouldShow) {
				visibleCount++;
				card.style.animation = "none";
				card.offsetHeight;
				card.style.animation = "";
			}
		});

		if (noResults && grid) {
			noResults.style.display = visibleCount === 0 ? "block" : "none";
		}
	}

	filters.forEach((btn) => {
		btn.addEventListener("click", () => {
			updateFilter(btn.dataset.tag ?? "all");
		});
	});
</script>
