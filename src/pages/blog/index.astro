---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import BlogPost from '@/components/BlogPost.astro';
import { BGPattern } from '@/components/ui/bg-pattern';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const posts = allPosts.sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
const totalReadingTime = posts.reduce((acc, post) => {
	return acc + (post.body ? Math.max(1, Math.ceil(post.body.trim().split(/\s+/).length / 200)) : 3);
}, 0);
---

<Layout>
	<main>
		<section class="relative pt-32 pb-20 px-5 overflow-hidden">
			<BGPattern variant="dots" mask="fade-edges" size={24} fill="hsl(var(--foreground) / 0.04)" />
			<div class="absolute inset-0 -z-10">
				<div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-primary/10 rounded-full blur-3xl" />
				<div class="absolute top-20 right-1/4 w-72 h-72 bg-purple-500/5 rounded-full blur-3xl" />
			</div>
			<div class="max-w-4xl mx-auto text-center">
				<div class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-medium mb-6 bg-secondary/50 text-secondary-foreground backdrop-blur-sm">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75" />
						<span class="relative inline-flex rounded-full h-2 w-2 bg-primary" />
					</span>
					{posts.length} {posts.length === 1 ? 'article' : 'articles'} published
				</div>
				<h1 class="text-4xl md:text-6xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-primary via-purple-500 to-pink-500">
					Blog
				</h1>
				<p class="text-lg text-muted-foreground max-w-2xl mx-auto leading-relaxed">
					Thoughts on software engineering, web development, and building things that matter.
				</p>
			</div>

			<div class="max-w-2xl mx-auto mt-10 grid grid-cols-3 gap-4">
				<div class="rounded-xl border bg-card/50 backdrop-blur-sm p-4 text-center">
					<span class="text-2xl font-bold text-foreground">{posts.length}</span>
					<p class="text-xs text-muted-foreground mt-1">Articles</p>
				</div>
				<div class="rounded-xl border bg-card/50 backdrop-blur-sm p-4 text-center">
					<span class="text-2xl font-bold text-foreground">{allTags.length}</span>
					<p class="text-xs text-muted-foreground mt-1">Topics</p>
				</div>
				<div class="rounded-xl border bg-card/50 backdrop-blur-sm p-4 text-center">
					<span class="text-2xl font-bold text-foreground">{totalReadingTime}</span>
					<p class="text-xs text-muted-foreground mt-1">Min read</p>
				</div>
			</div>
		</section>

		<section class="relative pb-24 px-5">
			<BGPattern variant="grid" mask="fade-top" size={32} fill="hsl(var(--foreground) / 0.03)" />
			<div class="max-w-6xl mx-auto">
				{allTags.length > 0 && (
					<div class="flex flex-wrap justify-center gap-2 mb-12">
						<button
							class="tag-filter inline-flex items-center rounded-full border px-4 py-1.5 text-sm font-medium transition-all duration-300 hover:bg-accent hover:text-accent-foreground cursor-pointer data-[active=true]:bg-foreground data-[active=true]:text-background data-[active=true]:border-foreground data-[active=true]:shadow-lg"
							data-tag="all"
							data-active="true"
						>
							All Posts
						</button>
						{allTags.map((tag) => (
							<button
								class="tag-filter inline-flex items-center rounded-full border px-4 py-1.5 text-sm font-medium transition-all duration-300 hover:bg-accent hover:text-accent-foreground cursor-pointer data-[active=true]:bg-foreground data-[active=true]:text-background data-[active=true]:border-foreground data-[active=true]:shadow-lg"
								data-tag={tag}
							>
								#{tag}
							</button>
						))}
					</div>
				)}

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
					{posts.map((post, index) => (
						<div
							class="blog-card stagger-item"
							data-tags={post.data.tags.join(",")}
							style={`view-transition-name: blog-card-${index}`}
						>
							<BlogPost post={post} />
						</div>
					))}
				</div>

				{posts.length === 0 && (
					<div class="text-center py-32">
						<div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-secondary mb-6">
							<svg class="w-8 h-8 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
							</svg>
						</div>
						<p class="text-muted-foreground text-lg font-medium">No posts yet</p>
						<p class="text-muted-foreground/60 text-sm mt-1">Check back soon for new articles!</p>
					</div>
				)}

				{posts.length > 0 && (
					<div class="mt-16 max-w-md mx-auto text-center p-8 rounded-2xl border bg-card/30 backdrop-blur-sm">
						<svg class="w-8 h-8 text-primary mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
						</svg>
						<h3 class="text-lg font-semibold mb-1">Stay updated</h3>
						<p class="text-sm text-muted-foreground mb-4 leading-relaxed">
							Get notified when I publish new articles. No spam, unsubscribe anytime.
						</p>
						<form class="flex gap-2" onsubmit="return false;">
							<input
								type="email"
								placeholder="Enter your email"
								class="flex-1 rounded-lg border bg-background px-3 py-2 text-sm outline-none focus:border-primary transition-colors"
							/>
							<button
								type="submit"
								class="inline-flex items-center rounded-lg bg-foreground text-background px-4 py-2 text-sm font-medium hover:bg-foreground/90 transition-colors cursor-pointer"
							>
								Subscribe
							</button>
						</form>
					</div>
				)}
			</div>
		</section>
	</main>
</Layout>

<style is:global>
	.tag-filter[data-active="true"] {
		background-color: hsl(var(--foreground));
		color: hsl(var(--background));
		border-color: hsl(var(--foreground));
		box-shadow: 0 4px 14px 0 hsl(var(--foreground) / 0.15);
	}

	.dark .tag-filter[data-active="true"] {
		background-color: hsl(var(--foreground));
		color: hsl(var(--background));
		border-color: hsl(var(--foreground));
	}

	@keyframes stagger-fade-in {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.stagger-item {
		animation: stagger-fade-in 0.5s ease-out both;
	}

	.stagger-item:nth-child(1) { animation-delay: 0s; }
	.stagger-item:nth-child(2) { animation-delay: 0.05s; }
	.stagger-item:nth-child(3) { animation-delay: 0.1s; }
	.stagger-item:nth-child(4) { animation-delay: 0.15s; }
	.stagger-item:nth-child(5) { animation-delay: 0.2s; }
	.stagger-item:nth-child(6) { animation-delay: 0.25s; }
	.stagger-item:nth-child(7) { animation-delay: 0.3s; }
	.stagger-item:nth-child(8) { animation-delay: 0.35s; }
	.stagger-item:nth-child(9) { animation-delay: 0.4s; }
	.stagger-item:nth-child(10) { animation-delay: 0.45s; }

	@media (prefers-reduced-motion: reduce) {
		.stagger-item {
			animation: none;
		}
	}
</style>

<script>
	const filters = document.querySelectorAll<HTMLButtonElement>(".tag-filter");
	const cards = document.querySelectorAll<HTMLElement>(".blog-card");

	function updateFilter(activeTag: string) {
		filters.forEach((btn) => {
			const tag = btn.dataset.tag;
			btn.dataset.active = tag === activeTag ? "true" : "false";
		});

		cards.forEach((card) => {
			const tags = card.dataset.tags?.split(",") ?? [];
			const shouldShow = activeTag === "all" || tags.includes(activeTag);
			card.style.display = shouldShow ? "" : "none";
			if (shouldShow) {
				card.style.animation = "none";
				card.offsetHeight;
				card.style.animation = "";
			}
		});
	}

	filters.forEach((btn) => {
		btn.addEventListener("click", () => {
			updateFilter(btn.dataset.tag ?? "all");
		});
	});
</script>
