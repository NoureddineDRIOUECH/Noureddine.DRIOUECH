---
import "@/styles/global.css";
import { ScrollProgress } from "@/components/ui/scroll-progress";
import StarsCanvas from "@/components/ui/StarBackground";
import { DockBar } from "@/components/DockBar";
import { Toaster } from "@/components/ui/sonner";
import SplashCursor from "../ui/Animations/SplashCursor/SplashCursor";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

export interface Props {
  showEffects?: boolean;
}

const { showEffects = false } = Astro.props;

// Preload above-the-fold hero images instead of below-fold profile pic
const preloadResources = [
  { as: "image", href: "/mainIcons.svg", type: "image/svg+xml" },
  { as: "image", href: "/mainIconsdark.svg", type: "image/svg+xml" }
];

// SEO constants to avoid duplication
const SITE_URL = "https://noureddinedriouech.me/";
const SITE_TITLE = "Noureddine DRIOUECH | Software Engineer";
const SITE_DESCRIPTION = "Portfolio of Noureddine DRIOUECH, a Software Engineer specializing in building modern, full-stack web applications and scalable SaaS solutions. Let's connect and build something amazing.";
const PROFILE_IMAGE = "https://noureddinedriouech.me/NoureddineDRIOUECH.jpg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{SITE_TITLE}</title>
    <meta name="description" content={SITE_DESCRIPTION} />
    <meta
      name="keywords"
      content="Noureddine DRIOUECH, Noureddine Driouech, noureddine driouech, N. Driouech, n driouech, Software Engineer, Web Developer, Frontend Developer, Full-Stack Developer, React Developer, Astro Developer, SaaS, Portfolio, Casablanca, Morocco, noureddine driouech morocco, noureddine driouech software engineer, noureddine driouech portfolio, noureddine driouech github"
    />
    <style>
      html,
      body {
        text-align: center;
        scroll-behavior: smooth;
      }
    </style>
    <meta name="author" content="Noureddine DRIOUECH" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/Noureddine%20DRIOUECH.jpg" type="image/jpeg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Preload critical resources -->
    {preloadResources.map(resource => (
      <link rel="preload" href={resource.href} as={resource.as} type={resource.type}  />
    ))}
    
    <!-- Preconnect to external domains -->
    <link rel="preconnect" href="https://cdn.simpleicons.org" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:title" content={SITE_TITLE} />
    <meta property="og:description" content={SITE_DESCRIPTION} />
    <meta property="og:image" content={PROFILE_IMAGE} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={SITE_URL} />
    <meta property="twitter:title" content={SITE_TITLE} />
    <meta property="twitter:description" content={SITE_DESCRIPTION} />
    <meta property="twitter:image" content={PROFILE_IMAGE} />

    <!-- Structured Data for SEO -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Noureddine DRIOUECH",
        "alternateName": [
          "Noureddine Driouech",
          "noureddine driouech",
          "Noureddine DRIOUECH",
          "N. Driouech",
          "n driouech",
          "Noureddine",
          "Driouech"
        ],
        "url": "https://noureddinedriouech.me/",
        "image": "https://noureddinedriouech.me/NoureddineDRIOUECH.jpg",
        "sameAs": [
          "https://www.linkedin.com/in/noureddinedriouech/",
          "https://github.com/NoureddineDRIOUECH",
          "https://www.instagram.com/noureddine.driouech/",
          "https://www.upwork.com/freelancers/~01c6fba5436d52831a"
        ],
        "jobTitle": "Software Engineer",
        "worksFor": {
          "@type": "Organization",
          "name": "Freelance"
        },
        "description": "Software Engineer specializing in building modern, full-stack web applications and scalable SaaS solutions using technologies like React, Astro, and Node.js.",
        "alumniOf": [
          {
            "@type": "CollegeOrUniversity",
            "name": "ENSIASD"
          },
          {
            "@type": "CollegeOrUniversity",
            "name": "EST Sidi Bennour"
          }
        ],
        "knowsAbout": [
          "Software Development",
          "Frontend Development",
          "Full-Stack Development",
          "SaaS Architecture",
          "React",
          "Astro",
          "JavaScript",
          "TypeScript",
          "Node.js",
          "Python",
          "Laravel",
          "Tailwind CSS",
          "Docker",
          "Kubernetes",
          "Automation",
          "Web Scraping",
          "SEO"
        ],
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Casablanca",
          "addressCountry": "MA"
        }
      }
    </script>
    <script is:inline>
      // Optimized theme script - runs immediately to prevent flash
      const getThemePreference = () => {
        if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      };
      const isDark = getThemePreference() === "dark";
      document.documentElement.classList[isDark ? "add" : "remove"]("dark");

      // Defer the observer setup to after page load
      if (typeof window !== "undefined") {
        window.addEventListener("DOMContentLoaded", () => {
          if (typeof localStorage !== "undefined") {
            const observer = new MutationObserver(() => {
              const isDark = document.documentElement.classList.contains("dark");
              localStorage.setItem("theme", isDark ? "dark" : "light");
            });
            observer.observe(document.documentElement, {
              attributes: true,
              attributeFilter: ["class"],
            });
          }
        });
      }
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-E4HT3W4JFD" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-E4HT3W4JFD');
    </script>
  </head>
  <body>
    <DockBar client:visible />
    <slot />
    {
      showEffects && (
        <>
          <StarsCanvas client:idle />
          <SplashCursor client:idle />
        </>
      )
    }
    <ScrollProgress client:visible />
    <Toaster client:idle />


    <SpeedInsights />
    <Analytics />
  </body>
</html>
